<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting when the OS has decided
         to display the app. This theme determines the color of the background, the
         status bar, and the other elements that may be visible during the launch transition
         until Flutter paints its first frame. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Theme applied to the Flutter application to alter the appearance before
         you can render the Flutter application. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/normal_background</item>
    </style>
</resources>
