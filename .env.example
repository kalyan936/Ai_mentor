# ================================
# AI Mentor - Environment Variables
# ================================

# LLM Provider (groq, openai, anthropic, gemini)
LLM_PROVIDER=gemini

# Google Gemini API Key (FREE: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Free tier: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Model Configuration
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Database
DATABASE_URL=sqlite:///./ai_mentor.db

# FAISS Vector Store Path
VECTOR_STORE_PATH=./data/vector_store

# Code Execution
CODE_EXECUTION_TIMEOUT=10
CODE_EXECUTION_MAX_MEMORY_MB=256

# App Settings
APP_NAME=AI Mentor
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=8501
BACKEND_URL=http://localhost:8000
